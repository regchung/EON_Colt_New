# 展示用環境變數(單機展示包)。start-demo.sh 會把本檔複製成專案根目錄 .env。
# ⚠️ 僅供展示;正式上線請改用獨立、強隨機的金鑰與密碼。

# --- 資料庫(容器內,固定即可)---
POSTGRES_USER=eon_colt
POSTGRES_PASSWORD=eon_colt_pw
POSTGRES_DB=eon_colt
DATABASE_URL=postgresql+psycopg://eon_colt:eon_colt_pw@db:5432/eon_colt

# --- 對外 ---
BACKEND_CORS_ORIGINS=http://localhost:8080

# --- 矩陣 / 地理編碼 ---
# 預設 haversine:離線也能跑、免金鑰,展示足夠。
# 現場有網路且有 Map8 金鑰時,改 MATRIX_PROVIDER=map8 可得真實道路矩陣與更準路線。
MATRIX_PROVIDER=haversine
GEOCODER_PROVIDER=nominatim

# --- 金鑰(可留空;留空則該功能優雅降級)---
# 設定 Map8 金鑰可啟用「路線地圖」底圖與門牌級地理編碼(現場有網路時建議填)。
MAP8_API_KEY=
# 設定後可展示「AI 助理 / 文件匯入」(需網路)。展示不需要可留空。
ANTHROPIC_API_KEY=

# --- 認證(展示用)---
SECRET_KEY=demo-only-secret-please-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=demo2026

# --- 文件抽取器(展示維持 native)---
EXTRACTOR=native
