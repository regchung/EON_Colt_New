# PostgreSQL
POSTGRES_USER=eon_colt
POSTGRES_PASSWORD=eon_colt_pw
POSTGRES_DB=eon_colt
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+psycopg://eon_colt:eon_colt_pw@db:5432/eon_colt
BACKEND_CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# 地理編碼 provider:nominatim | map8
GEOCODER_PROVIDER=nominatim
GEOCODE_BATCH_LIMIT=50

# Nominatim(免費;台灣門牌覆蓋有限)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODER_USER_AGENT=EON-COLT/0.1 (fleet dispatch)
GEOCODE_RATE_SLEEP=1.1

# 圖霸 Map8(台灣本土門牌級 + 行車時間矩陣;需金鑰)
# 設定金鑰並把 GEOCODER_PROVIDER 改成 map8 即啟用
MAP8_API_KEY=
MAP8_BASE_URL=https://api.map8.zone

# 距離矩陣 provider:osrm(自架,免費) | map8 | haversine(直線備援)
MATRIX_PROVIDER=osrm
OSRM_URL=http://osrm:5000

# 文件抽取器:native(預設,輕量原生)| docling(本地版面/表格抽取,PII 不出機房;需另裝 docling)
EXTRACTOR=native

# AI 派遣(Claude API)— 設定後啟用 /dispatch/ai-analyze 等功能
ANTHROPIC_API_KEY=
AI_DISPATCH_MODEL=claude-haiku-4-5-20251001

# 認證(JWT)— 正式環境請務必改 SECRET_KEY 與管理員密碼
SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=720
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Ports exposed on host
BACKEND_PORT=8000
FRONTEND_PORT=8080
DB_PORT=5432
OSRM_PORT=5001

# Web Push (VAPID) — 司機端推播。產生金鑰:npx web-push generate-vapid-keys 或 py_vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
